# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/zzp?sslmode=require
SUPABASE_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_token

# Mollie (payments)
MOLLIE_API_KEY=test_your_mollie_key

# Vercel API
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_team_id

# GitHub (for template deployments)
GITHUB_TEMPLATE_REPO_URL=https://github.com/your-org/zzp
GITHUB_TEMPLATE_REPO_ID=your_repo_id

# Internal security
INTERNAL_API_SECRET=change_this_to_a_long_random_secret
MODERATOR_TOKEN=change_this_to_a_long_random_secret

# Cloudflare
CLOUDFLARE_API_TOKEN=your_cloudflare_token
CLOUDFLARE_ZONE_ID=your_zone_id
